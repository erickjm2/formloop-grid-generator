<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="13.0" ExtensionBundleVersion="1.0.0" ExtensionBundleId="com.formloop.grid-generator" xmlns="http://ns.adobe.com/extension/manifest/1.0">
    <ExtensionList>
        <Extension Id="com.formloop.grid-generator.panel" Version="1.0.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="ILST" Version="[26.0,99.9]" />
        </HostList>
        <LocalizationList>
            <Localization Locale="en_US" />
        </LocalizationList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="13.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
